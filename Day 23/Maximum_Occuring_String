#include <stdio.h>

int main() {
    char str[100];
    int i, freq[256] = {0};
    char maxChar;
    int max = 0;

    printf("Enter a string: ");
    scanf("%s", str);

    for (i = 0; str[i] != '\0'; i++)
        freq[(int)str[i]]++;

    for (i = 0; str[i] != '\0'; i++) {
        if (freq[(int)str[i]] > max) {
            max = freq[(int)str[i]];
            maxChar = str[i];
        }
    }

    printf("Maximum occurring character = %c\n", maxChar);
    printf("Frequency = %d\n", max);

    return 0;
}