#include <stdio.h>

int main() {
    int seats = 50;
    int book;

    printf("Total Available Seats = %d\n", seats);

    printf("Enter Number of Seats to Book: ");
    scanf("%d", &book);

    if(book <= seats) {
        seats -= book;
        printf("Booking Successful!\n");
        printf("Remaining Seats = %d\n", seats);
    } else {
        printf("Sorry! Not Enough Seats Available.\n");
    }

    return 0;
}