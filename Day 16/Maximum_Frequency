#include <stdio.h>

int main()
{
    int a[100], n, i, j;
    int maxCount = 0, count, element;

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    printf("Enter the elements:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }

    for(i = 0; i < n; i++)
    {
        count = 1;

        for(j = i + 1; j < n; j++)
        {
            if(a[i] == a[j])
            {
                count++;
            }
        }

        if(count > maxCount)
        {
            maxCount = count;
            element = a[i];
        }
    }

    printf("Maximum Frequency Element = %d", element);
    printf("\nFrequency = %d", maxCount);

    return 0;
}