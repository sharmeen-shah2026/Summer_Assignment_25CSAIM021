#include <stdio.h>

int main()
{
    int a[100], n, i, j, sum, found = 0;

    printf("Enter the number of elements: ");
    scanf("%d", &n);

    printf("Enter the elements:\n");
    for(i = 0; i < n; i++)
    {
        scanf("%d", &a[i]);
    }

    printf("Enter the required sum: ");
    scanf("%d", &sum);

    for(i = 0; i < n; i++)
    {
        for(j = i + 1; j < n; j++)
        {
            if(a[i] + a[j] == sum)
            {
                printf("Pair found: %d %d", a[i], a[j]);
                found = 1;
                break;
            }
        }

        if(found)
            break;
    }

    if(!found)
    {
        printf("No pair found");
    }

    return 0;
}